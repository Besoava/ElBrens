{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "description": { "type": "string", "description": "Product description" },
        "category": { "type": "string", "description": "Product category" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "List of image URLs" },
        "colors": { "type": "array", "items": { "type": "string" }, "description": "Available colors" },
        "sizes": { "type": "array", "items": { "type": "string" }, "description": "Available sizes" },
        "isLimited": { "type": "boolean", "description": "Whether the product is limited edition" },
        "isBestSeller": { "type": "boolean", "description": "Whether the product is a best seller" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["name", "price", "category", "images"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "customer"], "description": "User role" },
        "displayName": { "type": "string", "description": "User display name" }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerInfo": {
          "type": "object",
          "properties": {
            "firstName": { "type": "string" },
            "lastName": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "governorate": { "type": "string" },
            "zipCode": { "type": "string" }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "color": { "type": "string" },
              "size": { "type": "string" },
              "image": { "type": "string" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "shippingCost": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string", "description": "UID of the user who placed the order" }
      },
      "required": ["customerInfo", "items", "totalAmount", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Application configuration",
      "type": "object",
      "properties": {
        "shippingType": { "type": "string", "enum": ["free", "paid"] },
        "shippingCost": { "type": "number" },
        "telegramBotToken": { "type": "string" },
        "telegramChatId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Application settings"
    }
  }
}
